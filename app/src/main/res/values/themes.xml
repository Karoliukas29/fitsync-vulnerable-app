<resources>
    <style name="Theme.FitSync" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/fs_primary</item>
        <item name="colorPrimaryVariant">@color/fs_primary_dark</item>
        <item name="colorOnPrimary">@color/fs_on_primary</item>
        <item name="colorSurface">@color/fs_surface</item>
        <item name="android:colorBackground">@color/fs_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/fs_surface</item>
    </style>

    <style name="Theme.FitSync.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/fs_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.FitSync</item>
    </style>
</resources>
