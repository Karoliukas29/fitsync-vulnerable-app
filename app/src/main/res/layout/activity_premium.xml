<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="@dimen/page_margin" android:background="@color/fs_background">
    <ImageView android:layout_width="80dp" android:layout_height="80dp"
        android:src="@drawable/ic_fitsync_logo" android:layout_marginBottom="24dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/premium_title" android:textSize="28sp"
        android:textColor="@color/fs_badge_pro" android:textStyle="bold"/>
    <TextView android:id="@+id/tvPremiumSubtitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/premium_subtitle" android:textSize="14sp"
        android:textColor="@color/fs_text_secondary" android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp" android:gravity="center"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubscribeMonthly" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="@string/plan_monthly"
        android:layout_marginBottom="8dp"/>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubscribeAnnual"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:text="@string/plan_annual"/>
    <TextView android:id="@+id/tvPremiumStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="@color/fs_success"
        android:layout_marginTop="24dp" android:visibility="gone"
        android:text="✓ You are a Pro member"/>
</LinearLayout>
